# ═══════════════════════════════════════════════════════════
#  RocSpace — Environment Variables
#  Copy to .env and fill in your values. NEVER commit .env
# ═══════════════════════════════════════════════════════════

# ─── Cloudflare ──────────────────────────────────────────
CF_API_TOKEN=           # Workers API token (cfat_...)
CF_ACCOUNT_ID=37c44b4d3f192a627d20e46bdf910e79
CF_ZONE_ID=8df888939e609421ac15e6fdade11ad4

# ─── Gateway Token (worker auth for AI endpoints) ────────
GATEWAY_TOKEN=          # Bearer token for hermes-cloudflare gateway

# ─── Clerk Auth ──────────────────────────────────────────
CLERK_PK=pk_test_...   # Publishable key
CLERK_SK=sk_test_...   # Secret key (NEVER expose to client)

# ─── AI Providers (for Gateway worker) ───────────────────
OPENAI_API_KEY=sk-...          # OpenAI Direct (gpt-4o, gpt-4.1, o3, o4-mini, codex-mini)
OPENROUTER_API_KEY=sk-or-...   # OpenRouter
GROQ_API_KEY=gsk_...           # Groq
GOOGLE_AI_API_KEY=AIza...      # Google AI / Gemini

# ─── Solace PubSub+ ──────────────────────────────────────
SOLACE_API_TOKEN=       # Solace SEMP API token
SOLACE_BROKER=mr-connection-xxx.messaging.solace.cloud
SOLACE_VPN=roclace-cluster

# ─── Aiven PostgreSQL ────────────────────────────────────
AIVEN_TOKEN=            # Aiven API token
PG_HOST=pg-xxx.e.aivencloud.com
PG_PORT=21876
PG_USER=avnadmin
PG_PASSWORD=AVNS_...
PG_DATABASE=defaultdb

# ─── Cloud Run ───────────────────────────────────────────
CLOUDRUN_URL=https://ai-vitality-xxx.us-west1.run.app
GCP_PROJECT=yttriferous-magpie-16ppv

# ─── Oracle Cloud ────────────────────────────────────────
OCI_TENANCY=ocid1.tenancy.oc1..
OCI_USER=ocid1.user.oc1..
OCI_FINGERPRINT=xx:xx:xx:...
OCI_REGION=ap-singapore-1

# ─── Deploy via Wrangler ─────────────────────────────────
# Use wrangler for deploying Workers (handles ESM module format correctly)
# CLOUDFLARE_API_TOKEN=cfat_... CLOUDFLARE_ACCOUNT_ID=37c44b4d3f192a627d20e46bdf910e79 npx wrangler deploy
# For secrets: echo "VALUE" | CLOUDFLARE_API_TOKEN=... CLOUDFLARE_ACCOUNT_ID=... npx wrangler secret put SECRET_NAME --name worker-name
# ⚠️ Wrangler deploy WIPES existing secret bindings! Re-set secrets after deploy!
