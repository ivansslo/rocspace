{
  "name": "roadfx-full-stack",
  "version": "1.0.0",
  "description": "Full-stack AI orchestration platform - Event-driven multi-agent hub powered by Cloudflare Workers + Solace PubSub+ + CrewAI",
  "type": "module",
  "scripts": {
    "dev": "tsx src/server/index.ts",
    "build": "tsc && esbuild src/server/index.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "test": "vitest",
    "deploy:workers": "wrangler deploy",
    "deploy:crewai": "cd crewai && python run.py",
    "setup": "npm install && chmod +x scripts/*.sh tools/*.sh"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8",
    "ws": "^8.17.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.2",
    "@types/ws": "^8.5.10",
    "typescript": "^5.4.5",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.2",
    "vitest": "^1.6.0",
    "eslint": "^9.4.0",
    "wrangler": "^3.60.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
