# =============================================================
# ROADFX Full Stack — Environment Variables
# Deploys to EXISTING Cloudflare Workers (no new workers)
# =============================================================

# ── Gateway Auth ──
TOKEN=

# ── AI Providers ──
GROQ_KEY=
OR_KEY=
OR_PROV_KEY=
GEMINI_KEY=

# ── Cloudflare (for CI/CD deploy) ──
CF_ACCOUNT=
CF_AI_TOKEN=
CF_TOKEN=

# ── Integrations ──
CLAW_KEY=
CLAWLINK_KEY=
HONCHO_KEY=
TAILSCALE_KEY=

# ── Solace Event Mesh ──
SOLACE_URL=
SOLACE_USER=
SOLACE_PASS=
SOLACE_API_TOKEN=
SOLACE_SEMP_URL=
SOLACE_VIEW_USER=
SOLACE_VIEW_PASS=

# ── Clerk Auth ──
CLERK_PK=
CLERK_SK=

# ── MongoDB ──
MONGO_URI=

# ── Voyage AI (embeddings → MongoDB) ──
VOYAGE_API_KEY=

# ── Firebase (planning-with-ai-36675) ──
FIREBASE_API_KEY=███████
FIREBASE_PROJECT_ID=planning-with-ai-36675
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json

# ── Infrastructure ──
RENDER_KEY=
GITHUB_PAT=
LITELLM_MASTER_KEY=
HERMES_WEBUI_PASSWORD=

# ── Existing CF Workers (DO NOT create new) ──
# hermes-cloudflare  → Main Gateway (primary)
# hermes-webhook     → Mirror
# certve-webhook     → Backup
# cf-ai-factory      → CF AI Factory (60 models)
# rocspace-links     → Links Hub
# roadfx-gateway     → DEPRECATED (delete this worker)
