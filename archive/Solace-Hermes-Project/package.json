{
  "name": "solace-hermes-ai",
  "version": "15.4.0",
  "description": "Event-driven multi-agent AI orchestration hub powered by Solace PubSub+ and Cloudflare Workers",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --sourcemap --outfile=dist/server.js",
    "start": "node dist/server.js",
    "deploy:worker": "cd cloudflare-gateway && npx wrangler deploy",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@types/helmet": "^0.0.48",
    "compression": "^1.8.1",
    "express": "^4.19.2",
    "helmet": "^8.2.0"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "esbuild": "^0.21.5",
    "tsx": "^4.15.0",
    "typescript": "^5.5.2"
  }
}
