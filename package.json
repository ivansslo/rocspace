{
  "name": "rocspace",
  "version": "1.0.0",
  "private": true,
  "description": "RocSpace — AI Infrastructure Platform",
  "workspaces": [
    "packages/*",
    "workers/*",
    "apps/*",
    "pages/*",
    "cli"
  ],
  "scripts": {
    "build": "npm run build:gateway && npm run build:site",
    "build:gateway": "node scripts/build-gateway.mjs",
    "build:site": "node scripts/build-site.mjs",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "deploy": "npm run deploy:gateway && npm run deploy:site",
    "deploy:site": "node scripts/deploy-worker.mjs site --esm",
    "deploy:gateway": "node scripts/deploy-worker.mjs gateway --esm",
    "deploy:auth": "npm run deploy -w workers/auth",
    "deploy:ai": "npm run deploy -w workers/ai",
    "deploy:webhook": "npm run deploy -w workers/webhook",
    "deploy:r2": "npm run deploy -w workers/r2",
    "deploy:all": "npm run build && npm run deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "esbuild": "^0.25.12",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  },
  "packageManager": "npm@11.0.0",
  "engines": {
    "node": ">=20"
  }
}
